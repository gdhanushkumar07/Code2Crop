# Gemini API Key (from Google AI Studio)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (used for Whisper voice transcriptions)
GROQ_API_KEY=your_groq_api_key_here

# Twilio Credentials (for WhatsApp integration)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
NEXT_PUBLIC_WHATSAPP_NUMBER=14155238886

# Firebase Client Configuration (Public)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_client_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project

# Firebase Admin SDK Configuration (Server-side)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project.iam.gserviceaccount.com
# IMPORTANT: Put private key inside double quotes and escape newlines (e.g. "-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n")
FIREBASE_PRIVATE_KEY="your_firebase_private_key_here"

# Next.js Public Base URL (Required for WhatsApp Twilio media/audio callback access)
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app or https://your-domain.railway.app
